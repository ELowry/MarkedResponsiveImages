{
	"name": "marked-responsive-images",
	"version": "2.0.1",
	"description": "A robust marked extension for handling responsive images with srcset generation.",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/ELowry/MarkedResponsiveImages.git"
	},
	"bugs": {
		"url": "https://github.com/ELowry/MarkedResponsiveImages/issues"
	},
	"homepage": "https://github.com/ELowry/MarkedResponsiveImages#readme",
	"source": "src/index.js",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"unpkg": "./dist/index.iife.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"scripts": {
		"test": "node --test",
		"build": "tsdown src/index.js --format cjs,esm,iife --global-name MarkedResponsiveImages --clean && node -e \"import('node:fs').then(fs => fs.copyFileSync('src/index.d.ts', 'dist/index.d.ts'))\"",
		"dev": "tsdown src/index.js --format cjs,esm,iife --global-name MarkedResponsiveImages --watch",
		"lint": "eslint src",
		"format": "prettier --write \"src/**/*.{js,ts}\"",
		"check-format": "prettier --check \"src/**/*.{js,ts}\"",
		"prepublishOnly": "npm run build"
	},
	"files": [
		"dist",
		"src"
	],
	"keywords": [
		"marked",
		"markdown",
		"responsive-images",
		"srcset",
		"extension"
	],
	"author": "Eric Lowry",
	"license": "MIT",
	"peerDependencies": {
		"marked": ">=4.0.0"
	},
	"devDependencies": {
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"marked": "^17.0.1",
		"prettier": "^3.8.1",
		"prettier-plugin-css-order": "^2.2.0",
		"tsdown": "^0.21.4",
		"typescript": "^5.9.3"
	}
}
